{
  "$schema": "https://mintlify.com/docs.json",
  "name": "orxhestra",
  "theme": "mint",
  "colors": {
    "primary": "#3FE0A8",
    "light": "#3FE0A8",
    "dark": "#3FE0A8"
  },
  "logo": {
    "light": "/images/lockup.svg",
    "dark": "/images/lockup.svg"
  },
  "favicon": "/images/favicon.svg",
  "appearance": {
    "default": "dark"
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Getting Started",
            "icon": "play",
            "pages": ["index", "getting-started/installation", "getting-started/quickstart"]
          },
          {
            "group": "Composer",
            "icon": "wand-magic-sparkles",
            "pages": [
              "composer/overview",
              "composer/schema-reference",
              "composer/extending"
            ]
          },
          {
            "group": "Core Concepts",
            "icon": "book",
            "pages": ["concepts/agents", "concepts/events", "concepts/runner-sessions", "concepts/invocation-context"]
          },
          {
            "group": "Tools",
            "icon": "wrench",
            "pages": ["tools/overview", "tools/filesystem", "tools/artifacts", "tools/todo", "tools/long-running", "tools/confirmation"]
          },
          {
            "group": "Orchestration",
            "icon": "sitemap",
            "pages": ["orchestration/composite-agents", "orchestration/planners", "orchestration/skills", "orchestration/prompts"]
          },
          {
            "group": "Runtime",
            "icon": "bolt",
            "pages": ["runtime/streaming", "runtime/providers", "runtime/callbacks", "runtime/tracing", "runtime/structured-output", "runtime/human-in-the-loop"]
          },
          {
            "group": "CLI",
            "icon": "terminal",
            "pages": ["cli/overview", "cli/commands", "cli/memory", "cli/themes"]
          },
          {
            "group": "Integrations",
            "icon": "plug",
            "pages": ["integrations/a2a", "integrations/mcp"]
          }
        ]
      },
      {
        "tab": "Examples",
        "pages": ["examples"]
      },
      {
        "tab": "Architecture",
        "pages": ["architecture"]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "orxhestra-code",
        "href": "https://github.com/NicolaiLassen/orxhestra-code"
      },
      {
        "label": "PyPI",
        "href": "https://pypi.org/project/orxhestra/"
      },
      {
        "type": "github",
        "href": "https://github.com/NicolaiLassen/orxhestra"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "/getting-started/quickstart"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/NicolaiLassen/orxhestra",
      "x": "https://x.com/orxhestra"
    }
  },
  "contextual": {
    "options": ["copy", "view", "chatgpt", "claude"]
  },
  "feedback": {
    "thumbsRating": true,
    "suggestEdit": true,
    "raiseIssue": true
  },
  "seo": {
    "metatags": {
      "og:site_name": "orxhestra",
      "og:description": "Open-source Python framework for orchestrating multi-agent AI systems. Async streaming, composable agent hierarchies, and first-class MCP & A2A integration.",
      "og:image": "/images/lockup.svg",
      "twitter:card": "summary_large_image",
      "twitter:image": "/images/lockup.svg"
    },
    "indexing": "all"
  },
  "metadata": {
    "og:type": "website",
    "og:locale": "en_US"
  }
}
